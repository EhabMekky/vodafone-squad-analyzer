{
  "name": "allure-report-analyzer",
  "version": "2.0.0",
  "description": "Vodafone Allure test report analyzer - Web application",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "analyze": "node parseAllureReport.js",
    "analyze:example": "node parseAllureReport.js ./example-report.html --output-json analysis.json --output-html report.html"
