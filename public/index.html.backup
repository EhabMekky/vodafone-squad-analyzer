<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Vodafone Test Report Analyzer</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
            background: linear-gradient(135deg, #e60000 0%, #8b0000 100%);
            min-height: 100vh;
            padding: 20px;
        }

        .container {
            max-width: 1400px;
            margin: 0 auto;
        }

        .header {
            background: white;
            border-radius: 12px;
            padding: 40px;
            text-align: center;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
            margin-bottom: 30px;
        }

        .header h1 {
            color: #e60000;
            font-size: 2.5em;
            margin-bottom: 10px;
        }

        .header p {
            color: #666;
            font-size: 1.1em;
        }

        .content {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 30px;
        }

        .card {
            background: white;
            border-radius: 12px;
            padding: 30px;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
        }

        .card h2 {
            color: #e60000;
            margin-bottom: 20px;
            font-size: 1.8em;
        }

        .upload-area {
            border: 3px dashed #e60000;
            border-radius: 12px;
            padding: 60px 20px;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s ease;
            margin-bottom: 20px;
        }

        .upload-area:hover, .upload-area.drag-over {
            background: #fff5f5;
            border-color: #8b0000;
        }

        .upload-area.uploading {
            background: #f0f0f0;
            cursor: not-allowed;
        }

        .upload-icon {
            font-size: 4em;
            margin-bottom: 15px;
        }

        .upload-text {
            font-size: 1.2em;
            color: #666;
            margin-bottom: 10px;
        }

        .upload-hint {
            font-size: 0.9em;
            color: #999;
        }

        input[type="file"] {
            display: none;
        }

        .btn {
            background: #e60000;
            color: white;
            border: none;
            padding: 15px 40px;
            border-radius: 8px;
            font-size: 1.1em;
            cursor: pointer;
            transition: all 0.3s ease;
            display: inline-block;
            text-decoration: none;
        }

        .btn:hover:not(:disabled) {
            background: #8b0000;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(230, 0, 0, 0.3);
        }

        .btn:disabled {
            background: #ccc;
            cursor: not-allowed;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .info-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 15px;
            margin-bottom: 20px;
        }

        .info-card {
            background: #f8f9fa;
            padding: 15px;
            border-radius: 8px;
            border-left: 3px solid #e60000;
        }

        .info-label {
            color: #666;
            font-size: 0.85em;
            margin-bottom: 5px;
        }

        .info-value {
            color: #333;
            font-size: 1.1em;
            font-weight: 500;
        }

        .section-header {
            color: #e60000;
            margin: 30px 0 15px 0;
            padding-bottom: 10px;
            border-bottom: 2px solid #f0f0f0;
            font-size: 1.4em;
        }

        .test-table {
            width: 100%;
            border-collapse: collapse;
            background: white;
            border-radius: 8px;
            overflow: hidden;
            margin-bottom: 20px;
        }

        .test-table th {
            background: #e60000;
            color: white;
            padding: 12px;
            text-align: left;
            font-weight: 500;
        }

        .test-table td {
            padding: 10px 12px;
            border-bottom: 1px solid #f0f0f0;
        }

        .test-table tr:hover {
            background: #f8f9fa;
        }

        .status-badge {
            display: inline-block;
            padding: 3px 10px;
            border-radius: 12px;
            font-size: 0.85em;
            font-weight: 500;
        }

        .status-passed { background: #d4edda; color: #155724; }
        .status-failed { background: #f8d7da; color: #721c24; }
        .status-skipped { background: #d1ecf1; color: #0c5460; }
        .status-broken { background: #fff3cd; color: #856404; }

        .chart-bar {
            background: linear-gradient(90deg, #e60000 0%, #ff6b6b 100%);
            height: 24px;
            border-radius: 4px;
            transition: width 0.3s ease;
            position: relative;
        }

        .chart-label {
            position: absolute;
            right: 8px;
            top: 50%;
            transform: translateY(-50%);
            color: white;
            font-size: 0.85em;
            font-weight: 500;
        }

        .expandable {
            cursor: pointer;
            user-select: none;
        }

        .expandable:hover {
            background: #f0f0f0;
        }

        .details {
            display: none;
            padding: 10px;
            background: #fafafa;
            border-left: 3px solid #e60000;
            margin-top: 5px;
            font-size: 0.9em;
            color: #666;
        }

        .details.open {
            display: block;
        }

        .filter-controls {
            display: flex;
            gap: 15px;
            margin-bottom: 20px;
            padding: 15px;
            background: #f8f9fa;
            border-radius: 8px;
            flex-wrap: wrap;
            align-items: center;
        }

        .filter-label {
            font-weight: 600;
            color: #333;
            margin-right: 10px;
        }

        .filter-toggle {
            display: flex;
            align-items: center;
            gap: 8px;
            cursor: pointer;
            padding: 8px 15px;
            border-radius: 20px;
            background: white;
            border: 2px solid #ddd;
            transition: all 0.3s ease;
            user-select: none;
        }

        .filter-toggle:hover {
            border-color: #e60000;
            transform: translateY(-2px);
            box-shadow: 0 2px 8px rgba(230, 0, 0, 0.2);
        }

        .filter-toggle.active {
            border-color: #e60000;
            background: #e60000;
            color: white;
        }

        .filter-toggle input[type="checkbox"] {
            width: 18px;
            height: 18px;
            cursor: pointer;
        }

        .filter-count {
            display: inline-block;
            background: rgba(0, 0, 0, 0.1);
            padding: 2px 8px;
            border-radius: 10px;
            font-size: 0.85em;
            font-weight: 600;
        }

        .filter-toggle.active .filter-count {
            background: rgba(255, 255, 255, 0.3);
        }

        .test-row-hidden {
            display: none !important;
        }

        .stat-card {
            background: #f8f9fa;
            padding: 25px;
            border-radius: 8px;
            text-align: center;
            border-left: 4px solid #e60000;
        }

        .stat-value {
            font-size: 2.5em;
            font-weight: bold;
            color: #e60000;
            margin-bottom: 5px;
        }

        .stat-label {
            color: #666;
            font-size: 0.9em;
            text-transform: uppercase;
        }

        .pass-rate {
            text-align: center;
            padding: 40px 0;
            margin: 30px 0;
            background: #f8f9fa;
            border-radius: 12px;
        }

        .pass-rate-value {
            font-size: 4em;
            font-weight: bold;
            margin-bottom: 10px;
        }

        .pass-rate.good .pass-rate-value { color: #28a745; }
        .pass-rate.warning .pass-rate-value { color: #ffc107; }
        .pass-rate.bad .pass-rate-value { color: #dc3545; }

        .failures-list {
            max-height: 400px;
            overflow-y: auto;
            margin-bottom: 20px;
        }

        .failure-item {
            background: #fff5f5;
            padding: 15px;
            border-radius: 8px;
            margin-bottom: 10px;
            border-left: 4px solid #dc3545;
        }

        .failure-package {
            font-weight: bold;
            color: #e60000;
            margin-bottom: 5px;
        }

        .failure-count {
            color: #dc3545;
            font-size: 0.9em;
        }

        .reason-item {
            background: #fffbeb;
            padding: 15px;
            border-radius: 8px;
            margin-bottom: 10px;
            border-left: 4px solid #ffc107;
        }

        .reason-text {
            color: #333;
            line-height: 1.5;
            margin-bottom: 8px;
        }

        .reason-meta {
            color: #666;
            font-size: 0.85em;
        }

        .reason-badge {
            display: inline-block;
            background: #e60000;
            color: white;
            padding: 2px 8px;
            border-radius: 12px;
            font-size: 0.75em;
            margin-left: 5px;
        }

        .message {
            padding: 15px;
            border-radius: 8px;
            margin-bottom: 20px;
            display: none;
        }

        .message.success {
            background: #d4edda;
            color: #155724;
            border: 1px solid #c3e6cb;
            display: block;
        }

        .message.error {
            background: #f8d7da;
            color: #721c24;
            border: 1px solid #f5c6cb;
            display: block;
        }

        .loading {
            text-align: center;
            padding: 20px;
            color: #666;
        }

        .spinner {
            border: 4px solid #f3f3f3;
            border-top: 4px solid #e60000;
            border-radius: 50%;
            width: 40px;
            height: 40px;
            animation: spin 1s linear infinite;
            margin: 20px auto;
        }

        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        .hidden {
            display: none !important;
        }

        .vodafone-badge {
            display: inline-block;
            background: #e60000;
            color: white;
            padding: 5px 15px;
            border-radius: 20px;
            font-size: 0.85em;
            margin-left: 10px;
        }

        @media (max-width: 768px) {
            .content {
                grid-template-columns: 1fr;
            }
            
            .header h1 {
                font-size: 1.8em;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>📊 Vodafone Test Report Analyzer</h1>
            <p>Upload your Allure HTML report for instant analysis</p>
        </div>

        <div class="content">
            <!-- Upload Section -->
            <div class="card">
                <h2>📤 Upload Report</h2>
                
                <div id="uploadArea" class="upload-area">
                    <div class="upload-icon">📁</div>
                    <div class="upload-text">Click to upload or drag & drop</div>
                    <div class="upload-hint">Allure HTML reports only (max 50MB)</div>
                </div>

                <input type="file" id="fileInput" accept=".html" />
                
                <div id="uploadMessage" class="message"></div>

                <div id="uploadedInfo" class="hidden">
                    <p style="color: #28a745; margin-bottom: 10px;">✅ Report uploaded successfully!</p>
                    <button id="uploadNewBtn" class="btn">Upload New Report</button>
                </div>
            </div>

            <!-- Results Section -->
            <div class="card">
                <h2>📈 Analysis Results</h2>
                
                <div id="loadingState" class="loading hidden">
                    <div class="spinner"></div>
                    <p>Analyzing report...</p>
                </div>

                <div id="resultsArea" class="hidden">
                    <div class="stats-grid">
                        <div class="stat-card">
                            <div class="stat-value" id="totalTests">0</div>
                            <div class="stat-label">Total Tests</div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-value" id="passedTests">0</div>
                            <div class="stat-label">Passed</div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-value" id="failedTests">0</div>
                            <div class="stat-label">Failed</div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-value" id="skippedTests">0</div>
                            <div class="stat-label">Skipped</div>
                        </div>
                    </div>

                    <div id="passRateCard" class="pass-rate">
                        <div class="pass-rate-value" id="passRate">0%</div>
                        <div class="stat-label">Pass Rate</div>
                    </div>

                    <h3 class="section-header">⏱️ Execution Details</h3>
                    <div class="info-grid" id="executionDetails"></div>

                    <h3 class="section-header">📦 Test Categories</h3>
                    <div id="categoriesSection"></div>

                    <div id="failuresSection" class="hidden">
                        <h3 class="section-header">❌ Failed Packages</h3>
                        <div id="failuresList" class="failures-list"></div>
                    </div>

                    <div id="reasonsSection" class="hidden">
                        <h3 class="section-header">⚠️ Common Failure Reasons</h3>
                        <div id="reasonsList" class="failures-list"></div>
                    </div>

                    <div id="failureTypesSection" class="hidden">
                        <h3 class="section-header">🔍 Failure Types Distribution</h3>
                        <div id="failureTypesChart"></div>
                    </div>

                    <div id="testListSection" class="hidden">
                        <h3 class="section-header">📋 Detailed Test List <span style="font-size: 0.7em; color: #666;">(Click rows to expand)</span></h3>
                        
                        <div class="filter-controls">
                            <span class="filter-label">Filter by Status:</span>
                            <div class="filter-toggle active" id="filterPassed" onclick="toggleFilter('passed')">
                                <input type="checkbox" checked onchange="event.stopPropagation(); toggleFilter('passed')">
                                <span>✅ Passed</span>
                                <span class="filter-count" id="countPassed">0</span>
                            </div>
                            <div class="filter-toggle active" id="filterFailed" onclick="toggleFilter('failed')">
                                <input type="checkbox" checked onchange="event.stopPropagation(); toggleFilter('failed')">
                                <span>❌ Failed</span>
                                <span class="filter-count" id="countFailed">0</span>
                            </div>
                            <div class="filter-toggle active" id="filterSkipped" onclick="toggleFilter('skipped')">
                                <input type="checkbox" checked onchange="event.stopPropagation(); toggleFilter('skipped')">
                                <span>⏭️ Skipped</span>
                                <span class="filter-count" id="countSkipped">0</span>
                            </div>
                            <div class="filter-toggle active" id="filterBroken" onclick="toggleFilter('broken')">
                                <input type="checkbox" checked onchange="event.stopPropagation(); toggleFilter('broken')">
                                <span>⚠️ Broken</span>
                                <span class="filter-count" id="countBroken">0</span>
                            </div>
                            <button class="btn" style="padding: 8px 20px; font-size: 0.9em; margin-left: auto;" onclick="resetFilters()">Show All</button>
                        </div>
                        
                        <table class="test-table" id="testTable">
                            <thead>
                                <tr>
                                    <th>Test Name</th>
                                    <th style="width: 100px;">Status</th>
                                    <th style="width: 100px;">Duration</th>
                                    <th style="width: 200px;">Package</th>
                                </tr>
                            </thead>
                            <tbody id="testTableBody"></tbody>
                        </table>
                        <div id="noTestsMessage" style="display: none; text-align: center; padding: 30px; color: #999;">
                            No tests match the selected filters. Try selecting different status options.
                        </div>
                    </div>
                </div>

                <div id="noDataState" class="loading">
                    <p style="color: #999;">Upload a report to see analysis</p>
                </div>
            </div>
        </div>
    </div>

    <script>
        let currentAnalysisId = null;
        let currentAnalysis = null;

        const uploadArea = document.getElementById('uploadArea');
        const fileInput = document.getElementById('fileInput');
        const uploadMessage = document.getElementById('uploadMessage');
        const uploadedInfo = document.getElementById('uploadedInfo');
        const uploadNewBtn = document.getElementById('uploadNewBtn');
        const loadingState = document.getElementById('loadingState');
        const resultsArea = document.getElementById('resultsArea');
        const noDataState = document.getElementById('noDataState');

        // Upload area interactions
        uploadArea.addEventListener('click', () => fileInput.click());

        uploadArea.addEventListener('dragover', (e) => {
            e.preventDefault();
            uploadArea.classList.add('drag-over');
        });

        uploadArea.addEventListener('dragleave', () => {
            uploadArea.classList.remove('drag-over');
        });

        uploadArea.addEventListener('drop', (e) => {
            e.preventDefault();
            uploadArea.classList.remove('drag-over');
            const files = e.dataTransfer.files;
            if (files.length > 0) {
                handleFile(files[0]);
            }
        });

        fileInput.addEventListener('change', (e) => {
            if (e.target.files.length > 0) {
                handleFile(e.target.files[0]);
            }
        });

        uploadNewBtn.addEventListener('click', () => {
            resetUpload();
        });

        function resetUpload() {
            fileInput.value = '';
            uploadedInfo.classList.add('hidden');
            uploadMessage.className = 'message';
            resultsArea.classList.add('hidden');
            noDataState.classList.remove('hidden');
            currentAnalysisId = null;
            currentAnalysis = null;
        }

        async function handleFile(file) {
            if (!file.name.endsWith('.html')) {
                showMessage(uploadMessage, 'Only HTML files are allowed', 'error');
                return;
            }

            uploadArea.classList.add('uploading');
            loadingState.classList.remove('hidden');
            noDataState.classList.add('hidden');
            uploadMessage.className = 'message';

            const formData = new FormData();
            formData.append('reportFile', file);

            try {
                const response = await fetch('/api/upload', {
                    method: 'POST',
                    body: formData
                });

                const result = await response.json();

                if (response.ok && result.success) {
                    currentAnalysisId = result.analysisId;
                    currentAnalysis = result.analysis;
                    displayResults(result.analysis);
                    uploadedInfo.classList.remove('hidden');
                    showMessage(uploadMessage, 'Report analyzed successfully!', 'success');
                } else {
                    showMessage(uploadMessage, result.error || 'Upload failed', 'error');
                    noDataState.classList.remove('hidden');
                }
            } catch (error) {
                showMessage(uploadMessage, 'Error: ' + error.message, 'error');
                noDataState.classList.remove('hidden');
            } finally {
                uploadArea.classList.remove('uploading');
                loadingState.classList.add('hidden');
            }
        }

        function displayResults(analysis) {
            // Update stats
            document.getElementById('totalTests').textContent = analysis.total;
            document.getElementById('passedTests').textContent = analysis.passed;
            document.getElementById('failedTests').textContent = analysis.failed;
            document.getElementById('skippedTests').textContent = analysis.skipped;

            // Display execution details
            displayExecutionDetails(analysis);

            // Display test categories
            displayCategories(analysis);
            
            // Update pass rate
            const passRate = parseFloat(analysis.passRate);
            const passRateCard = document.getElementById('passRateCard');
            const passRateValue = document.getElementById('passRate');
            
            passRateValue.textContent = passRate + '%';
            passRateCard.className = 'pass-rate';
            
            if (passRate >= 90) {
                passRateCard.classList.add('good');
            } else if (passRate >= 70) {
                passRateCard.classList.add('warning');
            } else {
                passRateCard.classList.add('bad');
            }

            // Display failures by package
            const failuresSection = document.getElementById('failuresSection');
            const failuresList = document.getElementById('failuresList');
            
            if (Object.keys(analysis.failuresByPackage).length > 0) {
                failuresSection.classList.remove('hidden');
                failuresList.innerHTML = '';
                
                Object.entries(analysis.failuresByPackage).slice(0, 10).forEach(([pkg, data]) => {
                    const item = document.createElement('div');
                    item.className = 'failure-item';
                    
                    let reasonsHTML = '';
                    if (data.reasons && data.reasons.length > 0) {
                        reasonsHTML = '<div style="margin-top: 8px; padding-top: 8px; border-top: 1px solid #ffdddd;">';
                        data.reasons.slice(0, 3).forEach(reason => {
                            reasonsHTML += `<div style="font-size: 0.85em; color: #666; margin-top: 4px;">• ${reason}</div>`;
                        });
                        if (data.reasons.length > 3) {
                            reasonsHTML += `<div style="font-size: 0.85em; color: #999; margin-top: 4px;">... and ${data.reasons.length - 3} more</div>`;
                        }
                        reasonsHTML += '</div>';
                    }
                    
                    item.innerHTML = `
                        <div class="failure-package">${pkg}</div>
                        <div class="failure-count">${data.count} failed test(s)</div>
                        ${reasonsHTML}
                    `;
                    failuresList.appendChild(item);
                });
            } else {
                failuresSection.classList.add('hidden');
            }

            // Display common failure reasons
            const reasonsSection = document.getElementById('reasonsSection');
            const reasonsList = document.getElementById('reasonsList');
            
            if (analysis.failureReasons && analysis.failureReasons.length > 0) {
                reasonsSection.classList.remove('hidden');
                reasonsList.innerHTML = '';
                
                // Group reasons by similarity
                const reasonGroups = {};
                analysis.failureReasons.forEach(item => {
                    const key = item.reason.substring(0, 100); // Group similar reasons
                    if (!reasonGroups[key]) {
                        reasonGroups[key] = {
                            reason: item.reason,
                            count: 0,
                            packages: new Set(),
                            tests: []
                        };
                    }
                    reasonGroups[key].count++;
                    reasonGroups[key].packages.add(item.package);
                    reasonGroups[key].tests.push(item.test);
                });
                
                // Sort by count and display top reasons
                const sortedReasons = Object.values(reasonGroups)
                    .sort((a, b) => b.count - a.count)
                    .slice(0, 10);
                
                sortedReasons.forEach((group, index) => {
                    const item = document.createElement('div');
                    item.className = 'reason-item';
                    item.innerHTML = `
                        <div class="reason-text">
                            <strong>${index + 1}.</strong> ${group.reason}
                            <span class="reason-badge">${group.count}x</span>
                        </div>
                        <div class="reason-meta">
                            Affected packages: ${Array.from(group.packages).slice(0, 2).join(', ')}
                            ${group.packages.size > 2 ? ` +${group.packages.size - 2} more` : ''}
                        </div>
                    `;
                    reasonsList.appendChild(item);
                });
            } else {
                reasonsSection.classList.add('hidden');
            }

            // Display failure types distribution
            displayFailureTypes(analysis);

            // Display detailed test list
            displayTestList(analysis);

            resultsArea.classList.remove('hidden');
        }

        function displayExecutionDetails(analysis) {
            const container = document.getElementById('executionDetails');
            const totalSeconds = Math.round(analysis.duration / 1000);
            const minutes = Math.floor(totalSeconds / 60);
            const seconds = totalSeconds % 60;

            const details = [
                { label: 'Total Duration', value: `${minutes}m ${seconds}s` },
                { label: 'Average Test Time', value: `${(analysis.avgDuration / 1000).toFixed(2)}s` },
            ];

            if (analysis.longestTest) {
                details.push({ 
                    label: 'Longest Test', 
                    value: `${(analysis.longestTest.duration / 1000).toFixed(2)}s`,
                    sub: analysis.longestTest.name.substring(0, 40) + '...'
                });
            }

            if (analysis.shortestTest) {
                details.push({ 
                    label: 'Shortest Test', 
                    value: `${(analysis.shortestTest.duration / 1000).toFixed(2)}s`,
                    sub: analysis.shortestTest.name.substring(0, 40) + '...'
                });
            }

            container.innerHTML = details.map(item => `
                <div class="info-card">
                    <div class="info-label">${item.label}</div>
                    <div class="info-value">${item.value}</div>
                    ${item.sub ? `<div class="info-label" style="margin-top: 5px;">${item.sub}</div>` : ''}
                </div>
            `).join('');
        }

        function displayCategories(analysis) {
            const container = document.getElementById('categoriesSection');
            if (!analysis.categories || Object.keys(analysis.categories).length === 0) {
                container.innerHTML = '<p style="color: #999;">No category data available</p>';
                return;
            }

            const categories = Object.entries(analysis.categories).slice(0, 10);
            container.innerHTML = categories.map(([pkg, stats]) => {
                const passRate = stats.total > 0 ? ((stats.passed / stats.total) * 100).toFixed(1) : 0;
                return `
                    <div class="failure-item" style="border-left-color: ${stats.failed > 0 ? '#dc3545' : '#28a745'};">
                        <div class="failure-package">${pkg}</div>
                        <div style="margin-top: 8px; font-size: 0.9em;">
                            <div>✅ ${stats.passed} passed · ❌ ${stats.failed} failed · ⏭️ ${stats.skipped} skipped</div>
                            <div style="margin-top: 5px;">Pass rate: <strong style="color: ${passRate >= 80 ? '#28a745' : '#dc3545'}">${passRate}%</strong></div>
                            <div style="color: #666; margin-top: 3px;">Duration: ${(stats.duration / 1000).toFixed(1)}s</div>
                        </div>
                    </div>
                `;
            }).join('');
        }

        function displayFailureTypes(analysis) {
            const section = document.getElementById('failureTypesSection');
            const container = document.getElementById('failureTypesChart');
            
            if (!analysis.failureTypes || Object.keys(analysis.failureTypes).length === 0) {
                section.classList.add('hidden');
                return;
            }

            section.classList.remove('hidden');
            const total = Object.values(analysis.failureTypes).reduce((a, b) => a + b, 0);
            const maxCount = Math.max(...Object.values(analysis.failureTypes));

            container.innerHTML = Object.entries(analysis.failureTypes)
                .sort(([, a], [, b]) => b - a)
                .map(([type, count]) => {
                    const percentage = ((count / total) * 100).toFixed(1);
                    const width = (count / maxCount) * 100;
                    return `
                        <div style="margin-bottom: 15px;">
                            <div style="display: flex; justify-content: space-between; margin-bottom: 5px;">
                                <strong>${type}</strong>
                                <span style="color: #666;">${count} (${percentage}%)</span>
                            </div>
                            <div style="background: #f0f0f0; border-radius: 4px; overflow: hidden;">
                                <div class="chart-bar" style="width: ${width}%">
                                    <span class="chart-label">${count}</span>
                                </div>
                            </div>
                        </div>
                    `;
                }).join('');
        }

        let currentTestList = [];
        const activeFilters = {
            passed: true,
            failed: true,
            skipped: true,
            broken: true
        };

        function displayTestList(analysis) {
            const section = document.getElementById('testListSection');
            const tbody = document.getElementById('testTableBody');
            
            if (!analysis.testCases || analysis.testCases.length === 0) {
                section.classList.add('hidden');
                return;
            }

            section.classList.remove('hidden');
            
            // Sort: failed first, then by duration
            const sortedTests = [...analysis.testCases].sort((a, b) => {
                const statusOrder = { failed: 0, broken: 1, skipped: 2, passed: 3 };
                const aOrder = statusOrder[a.status] || 4;
                const bOrder = statusOrder[b.status] || 4;
                if (aOrder !== bOrder) return aOrder - bOrder;
                return b.duration - a.duration;
            });

            // Store for filtering
            currentTestList = sortedTests;

            // Update filter counts
            updateFilterCounts(analysis);

            // Show top 100 tests
            tbody.innerHTML = sortedTests.slice(0, 100).map((test, index) => {
                const statusClass = `status-${test.status}`;
                const durationMs = test.duration;
                const durationText = durationMs > 1000 
                    ? `${(durationMs / 1000).toFixed(2)}s` 
                    : `${durationMs}ms`;
                
                return `
                    <tr class="expandable test-row" data-status="${test.status}" onclick="toggleDetails(${index})">
                        <td>${test.name || 'Unnamed Test'}</td>
                        <td><span class="status-badge ${statusClass}">${test.status}</span></td>
                        <td>${durationText}</td>
                        <td style="font-size: 0.85em; color: #666;">${test.package}</td>
                    </tr>
                    <tr id="details-${index}" class="details" data-status="${test.status}">
                        <td colspan="4">
                            <strong>Full Name:</strong> ${test.name}<br>
                            <strong>Package:</strong> ${test.package}<br>
                            <strong>Duration:</strong> ${durationText}
                        </td>
                    </tr>
                `;
            }).join('');

            if (sortedTests.length > 100) {
                tbody.innerHTML += `
                    <tr class="test-row" data-status="all">
                        <td colspan="4" style="text-align: center; color: #999; font-style: italic;">
                            ... and ${sortedTests.length - 100} more tests
                        </td>
                    </tr>
                `;
            }
        }

        function updateFilterCounts(analysis) {
            document.getElementById('countPassed').textContent = analysis.passed || 0;
            document.getElementById('countFailed').textContent = analysis.failed || 0;
            document.getElementById('countSkipped').textContent = analysis.skipped || 0;
            document.getElementById('countBroken').textContent = analysis.broken || 0;
        }

        function toggleFilter(status) {
            activeFilters[status] = !activeFilters[status];
            
            // Update UI
            const filterBtn = document.getElementById(`filter${status.charAt(0).toUpperCase() + status.slice(1)}`);
            const checkbox = filterBtn.querySelector('input[type="checkbox"]');
            
            if (activeFilters[status]) {
                filterBtn.classList.add('active');
                checkbox.checked = true;
            } else {
                filterBtn.classList.remove('active');
                checkbox.checked = false;
            }
            
            // Apply filters
            applyFilters();
        }

        function applyFilters() {
            const rows = document.querySelectorAll('.test-row');
            let visibleCount = 0;
            
            rows.forEach(row => {
                const status = row.getAttribute('data-status');
                
                // Keep "all" rows visible
                if (status === 'all') {
                    return;
                }
                
                if (activeFilters[status]) {
                    row.classList.remove('test-row-hidden');
                    visibleCount++;
                } else {
                    row.classList.add('test-row-hidden');
                    // Also hide the details row
                    const detailsRow = row.nextElementSibling;
                    if (detailsRow && detailsRow.classList.contains('details')) {
                        detailsRow.classList.add('test-row-hidden');
                    }
                }
            });
            
            // Show/hide no results message
            const noTestsMsg = document.getElementById('noTestsMessage');
            const table = document.getElementById('testTable');
            if (visibleCount === 0) {
                table.style.display = 'none';
                noTestsMsg.style.display = 'block';
            } else {
                table.style.display = 'table';
                noTestsMsg.style.display = 'none';
            }
        }

        function resetFilters() {
            // Enable all filters
            Object.keys(activeFilters).forEach(status => {
                activeFilters[status] = true;
                const filterBtn = document.getElementById(`filter${status.charAt(0).toUpperCase() + status.slice(1)}`);
                const checkbox = filterBtn.querySelector('input[type="checkbox"]');
                filterBtn.classList.add('active');
                checkbox.checked = true;
            });
            
            applyFilters();
        }

        function toggleDetails(index) {
            const details = document.getElementById(`details-${index}`);
            if (details && !details.classList.contains('test-row-hidden')) {
                details.classList.toggle('open');
            }
        }
    </script>
</body>
</html>
